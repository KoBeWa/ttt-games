# Supabase – öffentliche Projekt-URL (wird auch im Browser verwendet)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase – anonymer/öffentlicher API-Key (wird im Browser verwendet)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase – Service Role Key (NUR serverseitig / in Sync-Scripts verwenden!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Direkter Supabase-URL-Alias für Sync-Scripts (fallback auf NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_URL=https://your-project.supabase.co

# Optional: URL für nflverse Wochenstatistiken (Sync-Script sync-playoff-points-nflverse.mjs)
# NFLVERSE_WEEK_STATS_URL=https://github.com/nflverse/nflverse-data/releases/download/stats_player/stats_player_week_2025.csv
